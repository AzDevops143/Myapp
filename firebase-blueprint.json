{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Subject": {
      "title": "Subject",
      "description": "A study subject (e.g., Mathematics)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Topic": {
      "title": "Topic",
      "description": "A specific topic within a subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subjectId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["not-started", "in-progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "notes": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "StudySession": {
      "title": "Study Session",
      "description": "A log of a study session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "subjectId": { "type": "string" },
        "durationMinutes": { "type": "integer" },
        "startTime": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["topicId", "durationMinutes", "startTime"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A daily habit to track",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "uid"]
    },
    "HabitLog": {
      "title": "Habit Log",
      "description": "A completion log for a habit on a specific date",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "habitId": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD format" },
        "completed": { "type": "boolean" }
      },
      "required": ["habitId", "date", "completed", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile"
    },
    "/users/{userId}/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "User study subjects"
    },
    "/users/{userId}/subjects/{subjectId}/topics/{topicId}": {
      "schema": "Topic",
      "description": "Topics within a subject"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "StudySession",
      "description": "User study logs"
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": "Habit",
      "description": "User habits"
    },
    "/users/{userId}/habitLogs/{logId}": {
      "schema": "HabitLog",
      "description": "Habit completion logs"
    }
  }
}
